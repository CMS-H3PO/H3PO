{
  "schema_version": 2,
  "corrections": [
    {
      "name": "top_pt_weight",
      "description": "CMS Top pT reweighting (Run 2 legacy style)",
      "version": 1,
      "inputs": [
        {"name": "pt", "type": "real"},
        {"name": "variation", "type": "string"}
      ],
      "output": {"name": "weight", "type": "real"},
      "data": {
        "nodetype": "category",
        "input": "variation",
        "content": [
          {
            "key": "nominal",
            "value": {
              "nodetype": "formula",
              "expression": "exp(0.0615 - 0.0005 * x)",
              "parser": "TFormula",
              "variables": ["pt"]
            }
          },
          {
            "key": "up",
            "value": {
              "nodetype": "formula",
              "expression": "exp(0.0615 - 2.0 * 0.0005 * x)",
              "parser": "TFormula",
              "variables": ["pt"]
            }
          },
          {
            "key": "down",
            "value": {
              "nodetype": "formula",
              "expression": "1.0",
              "parser": "TFormula",
              "variables": ["pt"]
            }
          }
        ]
      }
    }
  ]
} 
